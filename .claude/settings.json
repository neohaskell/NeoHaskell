{
  "autocompact_percentage_override": 75,
  "env": {
    "BASH_MAX_OUTPUT_LENGTH": "150000"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "[ \"$(git branch --show-current)\" != \"main\" ] || { echo '{\"block\": true, \"message\": \"Cannot edit on main branch. Create a feature branch first.\"}' >&2; exit 2; }",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -q '\\.hs\"'; then fourmolu --mode inplace $(echo \"$CLAUDE_TOOL_INPUT\" | grep -o '\"[^\"]*\\.hs\"' | tr -d '\"') 2>/dev/null; fi",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE 'Spec\\.hs\"'; then echo '{\"feedback\": \"Test file modified - remember to run: cabal test\"}'; fi",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(**/*)",
      "Edit",
      "Write",
      "MultiEdit",
      "Bash(cabal:*)",
      "Bash(hlint:*)",
      "Bash(fourmolu:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(find:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Read(.git/**)",
      "Write(.git/**)",
      "Read(dist-newstyle/**)",
      "Read(**/dist-newstyle/**)",
      "Read(installer/target/**)",
      "Read(**/target/**)",
      "Read(**/node_modules/**)",
      "Read(website/.astro/**)",
      "Read(website/dist/**)",
      "Read(**/.next/**)",
      "Read(**/build/**)",
      "Read(**/__pycache__/**)",
      "Read(**/.venv/**)"
    ]
  }
}
