#!/usr/bin/env bash
#
# Developer entrypoint — dispatches the shared human/agent dev tools.
# (Pipeline doctrine: every pipeline tool is a human tool; every new pipeline
# asset registers a verb here or it doesn't ship.)
#
# Implementations live in scripts/; all of them self-provision the pinned
# toolchain via scripts/with-toolchain — no need to be inside `nix develop`.
#
set -euo pipefail
cd "$(dirname "$0")"

usage() {
  cat <<'EOF'
usage: ./dev <verb> [args]

  watch [target]        start the resident typecheck watcher (ghcid, -O0);
                          writes errors to .ghcid-errors.txt (default: lib:nhcore)
  check [target]        quick typecheck status — reads the watcher's file
                          (instant), or one-shot typecheck of target if no watcher
  test "pattern" [suite]  run only matching specs, link-free (~4-9s;
                          default suite: nhcore-test-core)
  refresh [target]      re-warm the -O0 build after pull/branch switch;
                          prints modules-rebuilt (cache health)
  doctest               run the doctest suite
  test-all              run every test suite (colored human runner)
  lint [paths]          dialect gate: hlint with the dialect-first config
                          (same as CI; escape hatch documented in .hlint.yaml)
  codemap               regenerate codemap artifacts (signatures, MAP.md, ratchet)
  codemap-check         validate the codemap (ownership, globs, aliases, ratchet)
  adr-check             validate the ADR index in docs/decisions/README.md
  adr-website [--check]  (re)generate the website ADR pages — landing + one page
                          per ADR — from docs/decisions/ (also runs from pnpm
                          predev/prebuild/precheck; --check: fail if the tracked
                          landing page is out of sync)
  hiedb                 (re)build the symbol reference DB
  who-calls <sym> [mod] symbol references, grouped by capability
  where-defined <sym>   symbol definition site, capability-tagged
  api <query>           search the NeoHaskell API surface — by type
                          ("Text -> Int") or by name (toInt)
  spec-check [files]    validate contract-delta specs in docs/changes/
                          (--plan <spec>: review + test-impact joins;
                          --reviews-pr [base]: gate design-review records;
                          --criteria <spec>: criteria table as JSON;
                          --criteria-tests [base]: gate criterion proving-tests exist)
  spec-drift <spec|--pr>  verify the generated API surface honors a spec's
                          promised contract delta (PR-ready gate)
  pipeline <cmd>        pipeline run state (.pipeline/state.json): init,
                          status, advance, set, approve, park, resume,
                          validate — the resume-never-replans contract
  bench                 run the perf suites against telemetry/bench-budgets.json
                          (nightly in CI; needs POSTGRES_AVAILABLE=true for
                          the Postgres entries)
  testbed               run the testbed acceptance suite (Hurl) via the toolchain
  changelog <spec|--check|--append>  changelog entries from contract-delta specs
                          (breaking = a removed signature line; --check gates CI)
  revert <commit>       kill switch: open a revert PR for a merged change
                          (--dry-run to stage it locally without pushing)
  retrospect [--since D] weekly telemetry digest + recommendation recorder
                          (--record '<json>'; --set/--prune-golden lifecycle)
  telemetry <cmd>       pipeline run telemetry (runs.jsonl): start, stage, wait,
                          rebuilt, consult, finish, golden — pipeline-only by
                          doctrine (see telemetry/SCHEMA.md); never for ad-hoc runs
  workflow-check        static wiring checks for .github/workflows (hidden
                          artifacts, retrospect loop; CI-enforced)
  doctor                harness self-check: every script has a verb or a
                          reasoned exemption; no dangling verbs (CI-enforced)
  exec <cmd> [args]     run any command with the pinned toolchain
                          (e.g. ./dev exec ghc --version)

Measured baselines: telemetry/SCHEMA.md
EOF
}

VERB="${1:-}"
[ $# -gt 0 ] && shift

case "${VERB}" in
  watch)    exec scripts/watch "$@" ;;
  check)    exec scripts/check "$@" ;;
  test)     exec scripts/test-match "$@" ;;
  refresh)  exec scripts/refresh-dev-cache "$@" ;;
  doctest)  exec scripts/run-doctest "$@" ;;
  test-all) exec scripts/run-all-tests.sh "$@" ;;
  lint)     exec scripts/lint "$@" ;;
  codemap)  exec scripts/refresh-codemap "$@" ;;
  codemap-check) exec scripts/codemap-check "$@" ;;
  adr-check) exec scripts/adr-index-check "$@" ;;
  adr-website) exec scripts/adr-website "$@" ;;
  hiedb)    exec scripts/refresh-hiedb "$@" ;;
  who-calls) exec scripts/who-calls "$@" ;;
  where-defined) exec scripts/where-defined "$@" ;;
  api)      exec scripts/api "$@" ;;
  spec-check) exec scripts/spec-check "$@" ;;
  spec-drift) exec scripts/spec-drift "$@" ;;
  pipeline) exec scripts/pipeline-state "$@" ;;
  bench)    exec scripts/bench "$@" ;;
  testbed)  exec scripts/testbed "$@" ;;
  changelog) exec scripts/changelog "$@" ;;
  revert)   exec scripts/revert "$@" ;;
  retrospect) exec scripts/retrospect "$@" ;;
  telemetry) exec scripts/telemetry.py "$@" ;;
  workflow-check) exec scripts/workflow-check "$@" ;;
  doctor)   exec scripts/doctor "$@" ;;
  exec)     exec scripts/with-toolchain "$@" ;;
  ""|help|-h|--help) usage ;;
  *)
    echo "dev: unknown verb '${VERB}'" >&2
    usage >&2
    exit 2
    ;;
esac
