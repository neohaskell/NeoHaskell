#!/usr/bin/env python3
"""Generate the website ADR landing page from the audited ADR index.

Source of truth: docs/decisions/README.md (validated file-by-file by
scripts/adr-index-check — every NNNN-*.md appears exactly once with a status
matching its own `## Status` section). This script transcribes that audited
index into website/src/content/docs/adrs/index.mdx as a real, linked list —
so the website never carries a hand-maintained, unaudited copy that can drift.

Chain of trust:
  docs/decisions/*.md  --(adr-index-check)-->  docs/decisions/README.md
                       --(this script)------>  website/.../adrs/index.mdx

Modes:
  adr-website            (re)write the website page from the index
  adr-website --check    fail (exit 1) if the committed page is out of sync
  adr-website --self-test  fixtures (doctor/CI)

Run:  ./dev adr-website          CI: .github/workflows/checks.yml (adr-index job)
"""

import re
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent
INDEX = REPO_ROOT / "docs" / "decisions" / "README.md"
PAGE = REPO_ROOT / "website" / "src" / "content" / "docs" / "adrs" / "index.mdx"

# ADR sources are linked to their canonical location on GitHub — the website
# lists the decisions and links out, it does not duplicate 69 ADR bodies.
SOURCE_BASE = "https://github.com/neohaskell/NeoHaskell/blob/main/docs/decisions"

# Same row shape scripts/adr-index-check validates:
#   | [0069](0069-security-reviews-are-local.md) | Title … | Accepted |
ROW_RE = re.compile(r"^\|\s*\[(\d{4})\]\(([^)]+)\)\s*\|\s*(.+?)\s*\|\s*([^|]+?)\s*\|\s*$")

GENERATED_NOTICE = (
    "{/* GENERATED by scripts/adr-website from docs/decisions/README.md — do not "
    "edit by hand.\n    Regenerate: ./dev adr-website   Verify (CI): ./dev "
    "adr-website --check */}"
)


def parse_index(text):
    """Rows of the ADR index table: list of (num, filename, title, status).

    Skips the header/separator rows (they don't match ROW_RE) and any prose.
    """
    entries = []
    for line in text.splitlines():
        m = ROW_RE.match(line)
        if not m:
            continue
        num, filename, title, status = (g.strip() for g in m.groups())
        entries.append((num, filename, title, status))
    return entries


def render(entries):
    """Deterministic MDX for the ADR landing page."""
    lines = [
        "---",
        "title: Architecture Decision Records",
        "description: The architectural decisions behind NeoHaskell, with links "
        "to each record.",
        "---",
        "",
        "Architecture Decision Records (ADRs) capture the significant "
        "architectural decisions",
        "made while building NeoHaskell. Each record documents the **context** "
        "(why the decision",
        "was needed), the **decision** (what was chosen and why), and the "
        "**consequences** (what",
        "follows from it).",
        "",
        "ADRs are immutable: when a decision is reversed, a new ADR is written "
        "that references",
        "the original. The list below is generated from the "
        "[decisions index](https://github.com/neohaskell/NeoHaskell/blob/main/docs/decisions/README.md)"
        " in the repository.",
        "",
        GENERATED_NOTICE,
        "",
        "| ADR | Title | Status |",
        "| --- | ----- | ------ |",
    ]
    for num, filename, title, status in entries:
        lines.append(f"| [{num}]({SOURCE_BASE}/{filename}) | {title} | {status} |")
    lines.append("")
    return "\n".join(lines)


def build():
    return render(parse_index(INDEX.read_text(encoding="utf-8")))


def cmd_write():
    content = build()
    PAGE.write_text(content, encoding="utf-8")
    n = content.count("| [")
    print(f"adr-website: wrote {PAGE.relative_to(REPO_ROOT)} — {n} ADRs listed")
    return 0


def cmd_check():
    want = build()
    have = PAGE.read_text(encoding="utf-8") if PAGE.exists() else ""
    if want == have:
        n = want.count("| [")
        print(f"adr-website: OK — website ADR list in sync ({n} ADRs)")
        return 0
    print("adr-website: FAIL — website ADR page is out of sync with "
          "docs/decisions/README.md", file=sys.stderr)
    print("  regenerate with: ./dev adr-website", file=sys.stderr)
    return 1


def self_test():
    ok = True

    def check(name, cond):
        nonlocal ok
        print(f"  {'ok  ' if cond else 'FAIL'} {name}")
        ok = ok and cond

    sample = (
        "# Architecture Decision Records (ADRs)\n"
        "\n"
        "| ADR | Title | Status |\n"
        "| --- | ----- | ------ |\n"
        "| [0001](0001-initial-architecture-baseline.md) | Initial Baseline | Accepted |\n"
        "| [0055](0055-declarative-integrations-with-fakes.md) | Declarative Integrations | Proposed |\n"
        "\n"
        "## Creating New ADRs\n"
    )
    entries = parse_index(sample)
    check("parses exactly the two data rows (header skipped)", len(entries) == 2)
    check("captures number/file/title/status",
          entries[0] == ("0001", "0001-initial-architecture-baseline.md",
                         "Initial Baseline", "Accepted"))
    check("preserves Proposed status", entries[1][3] == "Proposed")

    out = render(entries)
    check("links to GitHub source, not a relative path",
          f"{SOURCE_BASE}/0001-initial-architecture-baseline.md" in out)
    check("no bare relative .md link leaks through",
          "](0001-initial-architecture-baseline.md)" not in out)
    check("carries a generated banner", "GENERATED by scripts/adr-website" in out)
    check("has valid frontmatter", out.startswith("---\ntitle: Architecture Decision Records"))
    check("render is deterministic", render(entries) == out)

    print("adr-website: self-test", "OK" if ok else "FAILED")
    return 0 if ok else 1


def main(argv):
    if not argv:
        return cmd_write()
    if argv[0] == "--check":
        return cmd_check()
    if argv[0] == "--self-test":
        return self_test()
    print(f"usage: adr-website [--check|--self-test]  (got {argv!r})", file=sys.stderr)
    return 2


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
