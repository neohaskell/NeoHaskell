#!/usr/bin/env python3
"""Generate the website ADR landing pages from the audited ADR index.

Source of truth: docs/decisions/README.md (validated file-by-file by
scripts/adr-index-check — every NNNN-*.md appears exactly once with a status
matching its own `## Status` section). This script transcribes that audited
index into the website ADR landing pages as a real, linked list — so the
website never carries a hand-maintained, unaudited copy that can drift.

Six pages are owned and synchronized: the English canonical page and one
translated page per locale (es, fr, hy, ja, ru). Each locale keeps its own
translated title, description, and explanatory intro; below that intro every
page renders the SAME canonical ADR table. ADR source records are written in
English, so the table carries English titles/statuses and links out to each
record on GitHub — a short note on each localized page says so.

Chain of trust:
  docs/decisions/*.md  --(adr-index-check)-->  docs/decisions/README.md
                       --(this script)------>  website/.../adrs/index.mdx (x6)

Modes:
  adr-website            (re)write every website page from the index
  adr-website --check    fail (exit 1) if any committed page is out of sync
  adr-website --self-test  fixtures (doctor/CI)

Run:  ./dev adr-website          CI: .github/workflows/checks.yml (adr-index job)
"""

import re
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent
INDEX = REPO_ROOT / "docs" / "decisions" / "README.md"
DOCS = REPO_ROOT / "website" / "src" / "content" / "docs"
PAGE = DOCS / "adrs" / "index.mdx"  # English canonical page

# ADR sources are linked to their canonical location on GitHub — the website
# lists the decisions and links out, it does not duplicate 69 ADR bodies.
SOURCE_BASE = "https://github.com/neohaskell/NeoHaskell/blob/main/docs/decisions"

# Same row shape scripts/adr-index-check validates:
#   | [0069](0069-security-reviews-are-local.md) | Title … | Accepted |
ROW_RE = re.compile(r"^\|\s*\[(\d{4})\]\(([^)]+)\)\s*\|\s*(.+?)\s*\|\s*([^|]+?)\s*\|\s*$")

GENERATED_NOTICE = (
    "{/* GENERATED by scripts/adr-website from docs/decisions/README.md — do not "
    "edit by hand.\n    Regenerate: ./dev adr-website   Verify (CI): ./dev "
    "adr-website --check */}"
)

# Translated pages. Each locale keeps its own title/description/intro; the ADR
# table itself is canonical English (ADR records are English), and `note`
# explains that on the page in the reader's language.
LOCALES = [
    {
        "lang": "es",
        "title": "Registros de Decisiones Arquitectónicas",
        "description": "Registros de decisiones arquitectónicas significativas en NeoHaskell.",
        "intro": [
            "Esta sección documenta las principales elecciones arquitectónicas realizadas durante el desarrollo de NeoHaskell y la razón detrás de cada decisión.",
            "Los ADRs siguen el formato: contexto, decisión y consecuencias.",
        ],
        "note": "Los registros ADR de origen se mantienen en inglés, por lo que la tabla siguiente muestra los títulos y estados canónicos en inglés, con un enlace a cada fuente en GitHub.",
    },
    {
        "lang": "fr",
        "title": "Dossiers de Décisions Architecturales",
        "description": "Dossiers des décisions architecturales significatives dans NeoHaskell.",
        "intro": [
            "Cette section documente les choix architecturaux clés effectués pendant le développement de NeoHaskell et la logique derrière chaque décision.",
            "Les ADR suivent le format : contexte, décision, et conséquences.",
        ],
        "note": "Les enregistrements ADR d'origine sont tenus en anglais ; le tableau ci-dessous affiche donc les titres et statuts canoniques en anglais, avec un lien vers chaque source sur GitHub.",
    },
    {
        "lang": "hy",
        "title": "Կառուցվածքային Որոշումների Ձայնագրություններ",
        "description": "NeoHaskell-ի նշանակալի ճարտարապետական որոշումների ձայնագրություններ։",
        "intro": [
            "Այս բաժինը նկարագրում է NeoHaskell-ի մշակման ընթացքում կատարված հիմնական ճարտարապետական ընտրությունները և յուրաքանչյուր որոշման հիմքում ընկած պատճառաբանությունը։",
            "ADRs-ը հետևում են ձևաչափին. համատեքստ, որոշում և հետևանքներ։",
        ],
        "note": "ADR-ի սկզբնաղբյուր գրառումները պահվում են անգլերենով, ուստի ստորև բերված աղյուսակը ցույց է տալիս կանոնական վերնագրերն ու կարգավիճակներն անգլերենով՝ հղում կատարելով GitHub-ի յուրաքանչյուր աղբյուրին։",
    },
    {
        "lang": "ja",
        "title": "アーキテクチャ決定記録",
        "description": "NeoHaskellにおける重要なアーキテクチャ上の決定の記録。",
        "intro": [
            "このセクションでは、NeoHaskellの開発中に行われた主要なアーキテクチャの選択と、その各決定の背後にある理由を記録します。",
            "ADRは、コンテキスト、決定、そしてその結果という形式に従います。",
        ],
        "note": "ADRの原本は英語で管理されているため、以下の表は正規のタイトルとステータスを英語で示し、GitHub上の各ソースにリンクしています。",
    },
    {
        "lang": "ru",
        "title": "Записи о принятых архитектурных решениях",
        "description": "Записи о значительных архитектурных решениях в NeoHaskell.",
        "intro": [
            "Этот раздел документирует ключевые архитектурные выборы, сделанные во время разработки NeoHaskell, и обоснование каждого решения.",
            "ADRs следуют формату: контекст, решение и последствия.",
        ],
        "note": "Исходные записи ADR ведутся на английском языке, поэтому в таблице ниже приведены канонические заголовки и статусы на английском со ссылкой на каждый источник на GitHub.",
    },
]


def locale_page(lang):
    """Filesystem path of a locale's ADR landing page."""
    return DOCS / lang / "adrs" / "index.mdx"


def parse_index(text):
    """Rows of the ADR index table: list of (num, filename, title, status).

    Skips the header/separator rows (they don't match ROW_RE) and any prose.
    """
    entries = []
    for line in text.splitlines():
        m = ROW_RE.match(line)
        if not m:
            continue
        num, filename, title, status = (g.strip() for g in m.groups())
        entries.append((num, filename, title, status))
    return entries


def table_lines(entries):
    """The canonical ADR table — identical on every page (English source)."""
    out = ["| ADR | Title | Status |", "| --- | ----- | ------ |"]
    for num, filename, title, status in entries:
        out.append(f"| [{num}]({SOURCE_BASE}/{filename}) | {title} | {status} |")
    return out


def render(entries):
    """Deterministic MDX for the English (canonical) ADR landing page."""
    lines = [
        "---",
        "title: Architecture Decision Records",
        "description: The architectural decisions behind NeoHaskell, with links "
        "to each record.",
        "---",
        "",
        "Architecture Decision Records (ADRs) capture the significant "
        "architectural decisions",
        "made while building NeoHaskell. Each record documents the **context** "
        "(why the decision",
        "was needed), the **decision** (what was chosen and why), and the "
        "**consequences** (what",
        "follows from it).",
        "",
        "ADRs are immutable: when a decision is reversed, a new ADR is written "
        "that references",
        "the original. The list below is generated from the "
        "[decisions index](https://github.com/neohaskell/NeoHaskell/blob/main/docs/decisions/README.md)"
        " in the repository.",
        "",
        GENERATED_NOTICE,
        "",
    ]
    lines += table_lines(entries)
    lines.append("")
    return "\n".join(lines)


def render_localized(loc, entries):
    """Deterministic MDX for a translated ADR landing page.

    Keeps the locale's translated title/description/intro, then a translated
    note and the canonical (English-source) ADR table.
    """
    lines = [
        "---",
        f"title: {loc['title']}",
        f"description: {loc['description']}",
        "---",
        "",
    ]
    for para in loc["intro"]:
        lines.append(para)
        lines.append("")
    lines.append(GENERATED_NOTICE)
    lines.append("")
    lines.append(loc["note"])
    lines.append("")
    lines += table_lines(entries)
    lines.append("")
    return "\n".join(lines)


def owned_pages():
    """Every (path, wanted-content) pair this script owns — English + locales."""
    entries = parse_index(INDEX.read_text(encoding="utf-8"))
    pages = [(PAGE, render(entries))]
    for loc in LOCALES:
        pages.append((locale_page(loc["lang"]), render_localized(loc, entries)))
    return pages


def _adr_count(content):
    return content.count("| [")


def build():
    """The English canonical page (kept for callers/tests that want just it)."""
    return render(parse_index(INDEX.read_text(encoding="utf-8")))


def cmd_write():
    pages = owned_pages()
    for path, content in pages:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(content, encoding="utf-8")
    n = _adr_count(pages[0][1])
    print(f"adr-website: wrote {len(pages)} pages — {n} ADRs each")
    return 0


def cmd_check():
    pages = owned_pages()
    missing = []
    drift = []
    for path, want in pages:
        if not path.exists():
            missing.append(path)
            continue
        if path.read_text(encoding="utf-8") != want:
            drift.append(path)
    if not missing and not drift:
        n = _adr_count(pages[0][1])
        print(f"adr-website: OK — {len(pages)} ADR pages in sync ({n} ADRs each)")
        return 0
    print("adr-website: FAIL — website ADR pages are out of sync with "
          "docs/decisions/README.md", file=sys.stderr)
    for path in missing:
        print(f"  missing:  {path.relative_to(REPO_ROOT)}", file=sys.stderr)
    for path in drift:
        print(f"  drifted:  {path.relative_to(REPO_ROOT)}", file=sys.stderr)
    print("  regenerate with: ./dev adr-website", file=sys.stderr)
    return 1


def self_test():
    ok = True

    def check(name, cond):
        nonlocal ok
        print(f"  {'ok  ' if cond else 'FAIL'} {name}")
        ok = ok and cond

    sample = (
        "# Architecture Decision Records (ADRs)\n"
        "\n"
        "| ADR | Title | Status |\n"
        "| --- | ----- | ------ |\n"
        "| [0001](0001-initial-architecture-baseline.md) | Initial Baseline | Accepted |\n"
        "| [0055](0055-declarative-integrations-with-fakes.md) | Declarative Integrations | Proposed |\n"
        "\n"
        "## Creating New ADRs\n"
    )
    entries = parse_index(sample)
    check("parses exactly the two data rows (header skipped)", len(entries) == 2)
    check("captures number/file/title/status",
          entries[0] == ("0001", "0001-initial-architecture-baseline.md",
                         "Initial Baseline", "Accepted"))
    check("preserves Proposed status", entries[1][3] == "Proposed")

    out = render(entries)
    check("links to GitHub source, not a relative path",
          f"{SOURCE_BASE}/0001-initial-architecture-baseline.md" in out)
    check("no bare relative .md link leaks through",
          "](0001-initial-architecture-baseline.md)" not in out)
    check("carries a generated banner", "GENERATED by scripts/adr-website" in out)
    check("has valid frontmatter", out.startswith("---\ntitle: Architecture Decision Records"))
    check("render is deterministic", render(entries) == out)

    # Localized generation: every locale keeps its own translated framing but
    # shares the canonical English ADR table.
    check("five translated locales configured", len(LOCALES) == 5)
    check("owns six pages total (English + five locales)", len(owned_pages()) == 6)
    for loc in LOCALES:
        lout = render_localized(loc, entries)
        tag = loc["lang"]
        check(f"[{tag}] keeps translated title in frontmatter",
              f"title: {loc['title']}" in lout)
        check(f"[{tag}] keeps translated description in frontmatter",
              f"description: {loc['description']}" in lout)
        check(f"[{tag}] keeps translated intro prose", loc["intro"][0] in lout)
        check(f"[{tag}] explains the table is English-source", loc["note"] in lout)
        check(f"[{tag}] renders the canonical table with GitHub links",
              f"{SOURCE_BASE}/0001-initial-architecture-baseline.md" in lout)
        check(f"[{tag}] carries a generated banner",
              "GENERATED by scripts/adr-website" in lout)
        check(f"[{tag}] has valid frontmatter",
              lout.startswith(f"---\ntitle: {loc['title']}"))
        check(f"[{tag}] shares the English row count",
              _adr_count(lout) == _adr_count(out))
        check(f"[{tag}] render is deterministic", render_localized(loc, entries) == lout)

    print("adr-website: self-test", "OK" if ok else "FAILED")
    return 0 if ok else 1


def main(argv):
    if not argv:
        return cmd_write()
    if argv[0] == "--check":
        return cmd_check()
    if argv[0] == "--self-test":
        return self_test()
    print(f"usage: adr-website [--check|--self-test]  (got {argv!r})", file=sys.stderr)
    return 2


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
