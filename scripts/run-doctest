#!/usr/bin/env bash
#
# Doctest gate (local: ./dev doctest; CI: test.yml `doctest` job).
#
# doctest interprets the target files directly with the GHC API — no cabal
# build involved:
#   - dependencies come from the dev-shell GHC's package DB (haskell.nix
#     shellFor preloads the full dependency closure). The DB is passed
#     explicitly because the doctest binary's baked-in ghc-paths GHC has a
#     BARE global db (verified 2026-07-08: 0 project deps visible).
#   - `cabal repl --with-ghc=doctest` does NOT work here: nhcore depends on
#     the Cabal LIBRARY, --with-ghc changes the configuration hash, and the
#     inplace dep rebuilds never exist for that plan ("cannot satisfy
#     -package-id Cabal-3.10.3.0-inplace", verified 2026-07-08).
#   - target files are DISCOVERED by grep: new doctests join the gate
#     automatically; doctest-free modules cost nothing.
#   - -i dirs and -X extensions are DERIVED from core/nhcore.cabal at
#     runtime, so this script cannot drift from the cabal file.
#
# The doctest binary is a shell.tool in nix/hix.nix — built against the
# project's own GHC (doctest links the GHC API; version match is required).
#
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "${SCRIPT_DIR}/.."

FILES=$(git grep -l -- '>>>' -- 'core/**/*.hs' | tr '\n' ' ' || true)
if [ -z "${FILES// /}" ]; then
  echo "doctest: no modules with doctest examples under core/ — nothing to do"
  exit 0
fi

# shellcheck disable=SC2086 # FILES/SRCS/EXTS are intentionally word-split
exec "${SCRIPT_DIR}/with-toolchain" bash -euo pipefail -c '
  # library hs-source-dirs (block form, 4-space indented entries)
  SRCS=$(awk "/^  hs-source-dirs:\$/{f=1;next} f&&/^    [a-z]/{printf \" -icore/%s\",\$1;next} f{exit}" core/nhcore.cabal)
  # default-extensions from the shared common_cfg block
  EXTS=$(awk "/default-extensions:/{f=1;next} f&&/^    [A-Z]/{printf \" -X%s\",\$1;next} f{exit}" core/nhcore.cabal)
  if [ -z "${SRCS}" ] || [ -z "${EXTS}" ]; then
    echo "run-doctest: could not derive -i/-X flags from core/nhcore.cabal (layout changed?)" >&2
    exit 2
  fi

  echo "doctest: checking: '"${FILES}"'"
  doctest ${SRCS} ${EXTS} "-package-db=$(ghc --print-libdir)/package.conf.d" -w '"${FILES}"'
'
