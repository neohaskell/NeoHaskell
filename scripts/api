#!/usr/bin/env bash
#
# Two-pass API search (pipeline Phase 4; two-pass design per Nick 2026-07-08).
# Engine: hoogle for BOTH passes; the filtering is two databases:
#
#   PASS 1 — .hoogle-neo.hoo    : ONLY nhcore + nhintegrations (the dialect),
#            ranked on top.
#   PASS 2 — .hoogle-vanilla.hoo: deps + boot libs, ALWAYS shown below with a
#            disclaimer (revised 2026-07-08: fuzzy type matches in pass 1 —
#            "String -> IO ()" → setGlobalConfig — were suppressing the
#            vanilla results that held the real answer, e.g. putStrLn).
#            Seeing the vanilla function informs the escape-hatch decision
#            (.hlint.yaml `within:` + belongs-in note; rule of three →
#            Core primitive) — or reveals what to respell (per the AGENTS.md
#            style table, the single source of the vanilla→dialect mapping).
#
# Databases are local build artifacts (gitignored), rebuilt by ./dev codemap
# or lazily here when missing.
#
# Usage:
#   ./dev api "Text -> Maybe Uuid"    # type-directed
#   ./dev api toInt                   # by name
#
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "${SCRIPT_DIR}/.."

[ $# -ge 1 ] || { echo "usage: ./dev api \"<type or name>\"" >&2; exit 2; }

# Load the toolchain env ONCE for the whole script: re-exec ourselves inside
# nix develop; with-toolchain's fingerprint fast path then makes every inner
# call direct (instant). Already inside a current env -> no re-exec at all.
if [ "${NEOHASKELL_SHELL_FP:-}" != "$("${SCRIPT_DIR}/toolchain-fp")" ]; then
  exec "${SCRIPT_DIR}/with-toolchain" "$0" "$@"
fi

NEO_DB=".hoogle-neo.hoo"
VAN_DB=".hoogle-vanilla.hoo"

if [ ! -f "${NEO_DB}" ] || [ ! -f "${VAN_DB}" ]; then
  echo "api: building hoogle databases (one-time; refreshed by ./dev codemap)…" >&2
  "${SCRIPT_DIR}/build-hoogle-dbs"
fi

# ── pass 1: the NeoHaskell surface (top of the list) ───────────────────────
# capture in full, slice afterwards — `hoogle | head` under pipefail dies
# with SIGPIPE (141) the moment a query has more results than the slice
NEO=$("${SCRIPT_DIR}/with-toolchain" hoogle --database="${NEO_DB}" --count=10 "$@")
NEO_HIT=1
if [ -z "${NEO}" ] || echo "${NEO}" | grep -q "^No results found"; then
  NEO_HIT=0
fi

if [ "${NEO_HIT}" = "1" ]; then
  echo "── NeoHaskell surface ──────────────────────────────────────────────────"
  echo "${NEO}"
else
  echo "── NeoHaskell surface: no matches ──────────────────────────────────────"
fi

# ── pass 2: vanilla (bottom, disclaimered; omitted entirely when empty) ────
VAN=$("${SCRIPT_DIR}/with-toolchain" hoogle --database="${VAN_DB}" --count=6 "$@")
if [ -n "${VAN}" ] && ! echo "${VAN}" | grep -q "^No results found"; then
  echo ""
  echo "── vanilla (deps + boot libs) — prefer the NeoHaskell results above ────"
  echo "   Using one of these anyway? Escape hatch first: .hlint.yaml within:"
  echo "   (justification + belongs-in note); rule of three → Core primitive."
  echo "${VAN}"
  [ "${NEO_HIT}" = "1" ] && exit 0 || exit 3
fi

if [ "${NEO_HIT}" = "1" ]; then exit 0; else exit 1; fi
