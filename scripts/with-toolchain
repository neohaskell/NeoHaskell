#!/usr/bin/env bash
#
# Run a command with the pinned project toolchain (pipeline Phase 1).
#
# Callers (scripts/dev-loop, test-match, refresh-dev-cache — and you) do NOT
# need to be inside `nix develop`: this wrapper enters it on demand, so the
# same script works from a bare host shell, an agent session, or CI.
#
#   scripts/with-toolchain cabal build all
#   scripts/with-toolchain ghcid --version
#
# Resolution: nix available -> ALWAYS `nix develop --command` (~0.4s warm);
# no nix -> host tools + loud warning.
#
# There is deliberately NO "already in a shell" fast path: an inherited
# IN_NIX_SHELL can be stale (predating flake changes), and "the command
# exists on PATH" proves nothing for ubiquitous tools (bash, python3) whose
# shell versions differ (e.g. python3-with-pyyaml). The fast path caused
# three real failures and saved 0.4s. Correct beats fast.
#
set -euo pipefail
cd "$(dirname "$0")/.."

if [ $# -eq 0 ]; then
  echo "usage: scripts/with-toolchain <command> [args…]" >&2
  exit 2
fi

if command -v nix >/dev/null 2>&1; then
  exec nix develop --command "$@"
else
  echo "with-toolchain: nix not found — falling back to host tools (version-drift risk)" >&2
  exec "$@"
fi
