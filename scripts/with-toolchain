#!/usr/bin/env bash
#
# Run a command with the pinned project toolchain (pipeline Phase 1).
#
# Callers (scripts/dev-loop, test-match, refresh-dev-cache — and you) do NOT
# need to be inside `nix develop`: this wrapper enters it on demand, so the
# same script works from a bare host shell, an agent session, or CI.
#
#   scripts/with-toolchain cabal build all
#   scripts/with-toolchain ghcid --version
#
# Resolution:
#   1. FINGERPRINT-VERIFIED fast path (added 2026-07-08): the flake shellHook
#      exports NEOHASKELL_SHELL_FP = hash of the shell-defining files
#      (scripts/toolchain-fp, the single source). If the env's fingerprint
#      matches the CURRENT hash AND the command exists -> run directly,
#      instant. A config change or a stale/foreign shell mismatches -> re-enter.
#      (The old trust-based fast path — "IN_NIX_SHELL is set" — caused three
#      real failures and was removed; this one verifies instead of trusting.)
#   2. nix available -> `nix develop --command` (~0.4s warm eval).
#   3. no nix -> host tools + loud warning.
#
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "${SCRIPT_DIR}/.."

if [ $# -eq 0 ]; then
  echo "usage: scripts/with-toolchain <command> [args…]" >&2
  exit 2
fi

if [ -n "${NEOHASKELL_SHELL_FP:-}" ] \
   && [ "${NEOHASKELL_SHELL_FP}" = "$("${SCRIPT_DIR}/toolchain-fp")" ] \
   && command -v "$1" >/dev/null 2>&1; then
  exec "$@"
fi

if command -v nix >/dev/null 2>&1; then
  exec nix develop --command "$@"
else
  echo "with-toolchain: nix not found — falling back to host tools (version-drift risk)" >&2
  exec "$@"
fi
