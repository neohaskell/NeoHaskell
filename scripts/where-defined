#!/usr/bin/env bash
#
# Where is this symbol defined? (pipeline Phase 3)
# Usage: ./dev where-defined insert
#
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "${SCRIPT_DIR}/.."

NAME="${1:?usage: where-defined <symbol>}"

if [ ! -f .hiedb ]; then
  echo "where-defined: no index — run ./dev hiedb first" >&2
  exit 2
fi

"${SCRIPT_DIR}/with-toolchain" bash -c "
  hiedb -D .hiedb name-def '${NAME}' | python3 codemap/join-refs.py
"
