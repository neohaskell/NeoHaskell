#!/usr/bin/env bash
#
# Who references this symbol? (pipeline Phase 3 — plan-time edit-set expansion:
# "I'm changing this signature; what breaks?")
#
# Output is joined against codemap/capabilities.yaml so results read as
# capabilities, not bare file lists.
#
# Usage:
#   ./dev who-calls insert            # by symbol name
#   ./dev who-calls insert Service.EventStore.Core   # narrowed by module
#
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "${SCRIPT_DIR}/.."

NAME="${1:?usage: who-calls <symbol> [module]}"
MODULE="${2:-}"

if [ ! -f .hiedb ]; then
  echo "who-calls: no index — run ./dev hiedb first" >&2
  exit 2
fi

# hiedb name-refs prints "Module:line:col-..." lines; join to capabilities.
"${SCRIPT_DIR}/with-toolchain" bash -c "
  hiedb -D .hiedb name-refs '${NAME}' ${MODULE:+'${MODULE}'} | python3 codemap/join-refs.py
"
