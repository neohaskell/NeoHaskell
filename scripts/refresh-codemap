#!/usr/bin/env bash
#
# Regenerate the codemap's generated artifacts (pipeline Phase 3):
#   codemap/signatures/*.txt  — hoogle-format API surface, split per namespace
#   codemap/MAP.md            — human/agent render of capabilities.yaml
#   codemap/.doc-ratchet      — module-header + exported-function doc counters
#
# Run after changing exported APIs; CI verifies via git diff (sync check).
# Usage: ./dev codemap
#
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "${SCRIPT_DIR}/.."

echo "codemap: generating hoogle signatures (cabal haddock)…"
# CODEMAP_PROJECT lets CI reuse its default-flavor build (locally the dev
# flavor is the warm one). Output is flavor-independent.
"${SCRIPT_DIR}/with-toolchain" cabal haddock lib:nhcore lib:nhintegrations \
  --haddock-hoogle --project-file="${CODEMAP_PROJECT:-cabal.project.dev}" -v0 >/dev/null

echo "codemap: splitting + rendering…"
"${SCRIPT_DIR}/with-toolchain" python3 codemap/generate.py

echo "codemap: refreshing ./dev api hoogle databases…"
exec "${SCRIPT_DIR}/build-hoogle-dbs"
