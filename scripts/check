#!/usr/bin/env bash
#
# Quick typecheck status (pipeline Phase 1). THE verb agents and humans call
# after an edit — instantaneous when the watcher is running.
#
#   ./dev check
#
# Reads the watcher's output file (.ghcid-errors.txt, rewritten by
# `./dev watch` on every save). If no watcher is running, falls back to a
# one-shot incremental typecheck (a few seconds at -O0).
#
# Exit code: 0 = typechecks, 1 = errors.
#
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "${SCRIPT_DIR}/.."

TARGET="${1:-lib:nhcore}"
# CHECK_ERRORS_FILE override exists for ./dev doctor's fixture self-test —
# it exercises THIS code path against a canned GHC error, so a GHC bump
# that rewords the message breaks loudly instead of zeroing the metric.
OUT="${CHECK_ERRORS_FILE:-.ghcid-errors.txt}"

# invented-API event count (Phase 4, approximate/line-based): max of the
# wording match and the GHC error-index code match — codes (GHC-88464
# variable / GHC-76037 type) are stable by design, so a rewording of the
# English cannot silently zero the pipeline's headline metric.
count_invented() { # $1 = file with typecheck errors
  local wording codes
  wording=$(grep -ci "not in scope" "$1" || true)
  codes=$(grep -cE "GHC-(88464|76037)" "$1" || true)
  if [ "${wording}" -ge "${codes}" ]; then echo "${wording}"; else echo "${codes}"; fi
}

report_invented() { # $1 = count
  if [ "$1" -gt 0 ]; then
    echo "check: invented-api-events=$1 (symbol not in scope — resolve with ./dev api \"<name or type>\"; pipeline runs record this as invented-api)" >&2
  fi
}

if [ -f "${OUT}" ]; then
  # mtime shown so a stale file (killed watcher) is detectable at a glance.
  echo "check: from watcher (file updated $(date -r "${OUT}" '+%H:%M:%S')):"
  cat "${OUT}"
  if [ ! -s "${OUT}" ] || grep -q "All good" "${OUT}"; then
    exit 0
  else
    report_invented "$(count_invented "${OUT}")"
    exit 1
  fi
else
  echo "check: no watcher running (start one with ./dev watch) — one-shot typecheck of ${TARGET}:" >&2
  BUILD_LOG=$(mktemp)
  if "${SCRIPT_DIR}/with-toolchain" cabal build "${TARGET}" --project-file=cabal.project.dev >"${BUILD_LOG}" 2>&1; then
    tail -5 "${BUILD_LOG}"
    rm -f "${BUILD_LOG}"
    exit 0
  else
    tail -15 "${BUILD_LOG}"
    report_invented "$(count_invented "${BUILD_LOG}")"
    rm -f "${BUILD_LOG}"
    exit 1
  fi
fi
