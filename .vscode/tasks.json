{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "process",
      "command": "./dev",
      "args": ["check"],
      "label": "dev: check (typecheck)",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "type": "process",
      "command": "./dev",
      "args": ["test", "${input:testPattern}"],
      "label": "dev: test (focused core)",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "group": {
        "kind": "test"
      },
      "problemMatcher": []
    },
    {
      "type": "process",
      "command": "./dev",
      "args": ["test-all"],
      "label": "dev: test-all (every suite)",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "testPattern",
      "type": "promptString",
      "description": "hspec --match pattern for ./dev test (default suite: nhcore-test-core)",
      "default": "EventStore"
    }
  ]
}
